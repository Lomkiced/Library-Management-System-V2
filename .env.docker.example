# =============================================================================
# Library Management System - Docker Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   copy .env.docker.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME="Library Management System"
APP_ENV=production
APP_KEY=                                    # Generated automatically on first run
APP_DEBUG=false
APP_URL=http://localhost:8000               # Change to http://<YOUR-LAN-IP>:8000

# -----------------------------------------------------------------------------
# Database Configuration
# Database Configuration (Secured Template)
# -----------------------------------------------------------------------------
DB_DATABASE=library_system
DB_USERNAME=library_app                     # Dedicated app user (not root)
DB_PASSWORD=                                # Set a strong password here
MYSQL_ROOT_PASSWORD=                        # Set a DIFFERENT strong root password
MYSQL_ALLOW_EMPTY_PASSWORD=no               # Enforce security

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_PASSWORD=null

# -----------------------------------------------------------------------------
# Laravel Sanctum (Authentication)
# ⚠️  Add your LAN IP + port for auth to work from other devices!
# Example: localhost,127.0.0.1,localhost:8000,127.0.0.1:8000,192.168.1.100,192.168.1.100:8000
# -----------------------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,localhost:8000,127.0.0.1:8000

# -----------------------------------------------------------------------------
# Session
# Leave empty to default to current domain (works for LAN IPs)
# -----------------------------------------------------------------------------
SESSION_DOMAIN=

# -----------------------------------------------------------------------------
# Nginx Ports
# The app will be accessible at http://<YOUR-IP>:<NGINX_HTTP_PORT>
# -----------------------------------------------------------------------------
NGINX_HTTP_PORT=8000
NGINX_HTTPS_PORT=8443

# -----------------------------------------------------------------------------
# Mail Configuration (Optional)
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@library.local"
MAIL_FROM_NAME="${APP_NAME}"
